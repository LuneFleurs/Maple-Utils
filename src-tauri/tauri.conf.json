{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maple Utils",
  "version": "0.1.0",
  "identifier": "com.sooda.maple-utils",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Maple Utils",
        "width": 480,
        "height": 700,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "focus": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
